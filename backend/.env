NODE_ENV=production
PORT=3001

# Database - PostgreSQL (Render or local)
DATABASE_URL=postgresql://user:password@host:5432/hemsolutions
DB_SSL=true

# Frontend URL (for CORS)
FRONTEND_URL=https://www.hemsolutions.se

# JWT Secret (generate strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email - Nodemailer (use your one.com email or SMTP)
SMTP_HOST=smtp.one.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@hemsolutions.se
SMTP_PASS=your-email-password
EMAIL_FROM=info@hemsolutions.se
EMAIL_FROM_NAME="HemSolutions Sverige AB"

# Admin credentials
ADMIN_EMAIL=info@hemsolutions.se
ADMIN_PASSWORD=your-secure-admin-password

# SMS - 46elks (Swedish SMS provider)
SMS_PROVIDER=46elks
ELKS_API_USERNAME=your-46elks-username
ELKS_API_PASSWORD=your-46elks-password
SMS_FROM=HemSolutions

# Payments - Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# BankID (ready for integration)
BANKID_ENABLED=false
BANKID_API_URL=https://appapi2.test.bankid.com/rp/v5.1

# Swish (ready for integration)
SWISH_ENABLED=false
SWISH_PHONE=your-swish-number
SWISH_PAYEE_ALIAS=your-payee-alias

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
